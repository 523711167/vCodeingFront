# 业务页面默认仍然走 mock，方便在列表接口未联调前继续开发。
VITE_APP_TITLE=内容运营后台
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
VITE_USE_MOCK=true
VITE_USE_USER_MOCK=true
VITE_USE_AUTH_MOCK=true
VITE_LOGIN_EXPIRE_CODE=40101

# OAuth2 默认走前端同源代理，避免开发时浏览器直接跨域请求 8080 导致 CORS。
VITE_OAUTH_BASE_URL=/oauth-proxy
VITE_OAUTH_PROXY_TARGET=http://127.0.0.1:8080
VITE_OAUTH_CLIENT_ID=workflow-client
VITE_OAUTH_CLIENT_SECRET=workflow-client-secret
VITE_OAUTH_SCOPE=api
VITE_IDLE_LOGOUT_MS=300000
